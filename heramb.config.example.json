{
  "project": "my-chat-app",
  "services": {
    "redis": {
      "provider": "upstash",
      "produces": ["REDIS_URL"]
    },
    "backend": {
      "provider": "railway",
      "path": "./backend",
      "serviceId": "your-railway-service-id",
      "needs": ["REDIS_URL"],
      "produces": ["BACKEND_URL"],
      "derives": {
        "WS_URL": "BACKEND_URL → wss://"
      }
    },
    "frontend": {
      "provider": "vercel",
      "path": "./frontend",
      "projectId": "your-vercel-project-name",
      "needs": ["NEXT_PUBLIC_API_URL", "NEXT_PUBLIC_WS_URL"],
      "produces": ["FRONTEND_URL"]
    },
    "backend-cors": {
      "action": "patch-env",
      "target": "backend",
      "vars": { "CORS_ORIGIN": "FRONTEND_URL" },
      "then": "redeploy"
    }
  },
  "wsConfig": {
    "pingInterval": 25000,
    "transport": "websocket-only"
  },
  "env": {
    "manual": ["JWT_SECRET", "DATABASE_URL"]
  }
}
