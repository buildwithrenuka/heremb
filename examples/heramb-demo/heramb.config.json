{
  "project": "heramb-demo",
  "services": {
    "backend": {
      "provider": "railway",
      "path": "./backend",
      "projectId": "5c0a1315-a12f-437f-930c-d2727b56d132",
      "serviceId": "bfae7bce-994b-49c2-8852-8d2533cf093b",
      "needs": [],
      "produces": ["BACKEND_URL"]
    },
    "frontend": {
      "provider": "vercel",
      "path": "./frontend",
      "projectId": "heramb-demo",
      "needs": ["VITE_API_URL"],
      "produces": ["FRONTEND_URL"]
    },
    "backend-cors": {
      "action": "patch-env",
      "target": "backend",
      "vars": { "CORS_ORIGIN": "FRONTEND_URL" },
      "then": "redeploy"
    }
  },
  "env": {
    "manual": []
  }
}
