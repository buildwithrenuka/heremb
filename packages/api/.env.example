JWT_SECRET=change-me-to-a-long-random-secret
WEB_URL=http://localhost:5173
API_URL=http://localhost:3001

# ── Optional OAuth (NOT required for sign-in) ─────────────────────────────
# Token sign-in works without these. Only enable if you want OAuth redirect buttons.
# GitHub OAuth app callback: http://localhost:3001/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google OAuth callback: http://localhost:3001/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — only for unknown deploy error diagnosis (never required)
OPENAI_API_KEY=

